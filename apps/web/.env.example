NUXT_PUBLIC_APP_URL=http://localhost:3000
NUXT_SESSION_SECRET=change-me

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NOVITA_API_KEY=
NOVITA_BASE_URL=https://api.novita.ai/openai
# Comma-separated hostnames allowed for outbound LLM calls (must include NOVITA_BASE_URL host)
NOVITA_ALLOWED_HOSTS=api.novita.ai
# Set to true only in dev to allow http://127.0.0.1 or http://localhost for local proxies
# ALLOW_INSECURE_LLM_HTTP=false
NOVITA_MODEL=google/gemma-3-12b-it

PDF_STORAGE_BUCKET=resumes
PDF_BASE_PATH=exports

ENCRYPTION_KEY=change-me
# Required for POST /api/internal/embeddings/run (do not reuse NUXT_SESSION_SECRET)
INTERNAL_WORKER_TOKEN=change-me
